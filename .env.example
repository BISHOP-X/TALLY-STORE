# Supabase Configuration
VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Ercas Pay Configuration
# Get your API keys from: https://dashboard.ercaspay.com/settings/api-keys

# Test Mode Keys (for development)
VITE_ERCAS_SECRET_KEY=ECRS-TEST-SKLVbpD1J7DG9fwwdyddcAkEysTKsYD564S1NDSUBS

# Live Mode Keys (for production)
# VITE_ERCAS_SECRET_KEY=ECRS-LIVE-your_secret_key_here

# Environment Mode (test or live)
VITE_ERCAS_MODE=test

# API Base URL (staging for test, live for production)
VITE_ERCAS_BASE_URL=https://api-staging.ercaspay.com/api/v1
# VITE_ERCAS_BASE_URL=https://api.ercaspay.com/api/v1

# PocketFi Configuration (second wallet top-up gateway, alongside Ercas Pay)
# These are NOT used client-side — set them as Supabase Edge Function secrets
# (Supabase dashboard > Edge Functions > create-pocketfi-topup > Secrets), not here:
#   POCKETFI_SECRET_KEY=your_pocketfi_secret_key
#   POCKETFI_BASE_URL=https://api.pocketfi.ng/v1   (confirm against PocketFi's current docs)
# Also set on Vercel (for api/webhook-pocketfi.ts, shared with the Ercas webhook):
#   VITE_SUPABASE_URL=...
#   SUPABASE_SERVICE_ROLE_KEY=...

# MuaBanVia Configuration (live auto-fulfillment when pre-stocked accounts run out)
# NOT used client-side — set as Supabase Edge Function secrets, shared by both
# muabanvia-fulfill and process-purchase functions
# (Supabase dashboard > Edge Functions > Secrets):
#   MUABANVIA_API_KEY=your_muabanvia_api_key
#   MUABANVIA_BASE_URL=https://api.muabanvia.com/api/v1   (confirm against MuaBanVia's current docs)
# Per-product auto-fulfillment is toggled in Admin > Edit Product Template
# (muabanvia_product_id + "Enable auto-fulfillment" checkbox) — no extra Vercel config needed.

# Example:
# VITE_SUPABASE_URL=https://abcdefghijklmnop.supabase.co
# VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Instructions:
# 1. Go to https://supabase.com and create a new project
# 2. Go to Settings > API in your Supabase dashboard
# 3. Copy your project URL and anon/public key
# 4. Go to https://dashboard.ercaspay.com and get your API keys
# 5. Replace the values above with your actual credentials
# 6. Rename this file to .env.local (remove .example)
